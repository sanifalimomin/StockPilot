# Dev-server proxy target for /api requests (see vite.config.ts).
# Defaults to the deployed ALB; override to a local backend if you run one.
# VITE_API_TARGET=http://localhost:8080
VITE_API_TARGET=http://ims-dev-alb-342622939.us-east-1.elb.amazonaws.com

# Build-time API origin for HOSTED builds (S3 website). Leave unset for dev —
# CI/CD sets it automatically from the deployed ALB (see .github/workflows/ci-cd.yml).
# VITE_API_BASE_URL=http://<alb-dns>

